{
  "name": "mmailpit",
  "version": "1.0.0",
  "description": "MCP server for Mailpit — interact with local test emails from Claude, Cursor, and other AI assistants",
  "type": "module",
  "bin": {
    "mmailpit": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir ./dist --target node",
    "typecheck": "tsc --noEmit",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}